- name: epy_block_4
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Block: Byte-to-PDU including idle\n\"\"\
      \"\n\nimport numpy as np\nfrom gnuradio import gr\nimport pmt\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Convert continuous byte stream (including idle) to PDUs\n \
      \   \"\"\"\n    def __init__(self, pdu_size=64):\n        gr.sync_block.__init__(\n\
      \            self,\n            name=\"ByteToPDUWithIdle\",\n            in_sig=[np.uint8],\n\
      \            out_sig=[]\n        )\n\n        self.message_port_register_out(pmt.intern(\"\
      pdus\"))\n\n        # Buffer to accumulate bytes before creating PDU\n     \
      \   self.byte_buffer = []\n\n        # How many bytes per PDU\n        self.pdu_size\
      \ = int(pdu_size)\n\n    def work(self, input_items, output_items):\n      \
      \  inp = input_items[0]\n        n_in = len(inp)\n\n        # Append all incoming\
      \ bytes (idle + packets) to buffer\n        self.byte_buffer.extend(inp.tolist())\n\
      \n\n        # Emit PDUs whenever buffer has enough bytes\n        while len(self.byte_buffer)\
      \ >= self.pdu_size:\n            pdu_bytes = self.byte_buffer[:self.pdu_size]\n\
      \            self.byte_buffer = self.byte_buffer[self.pdu_size:]\n\n       \
      \     # Create PMT vector\n            pdu = pmt.init_u8vector(len(pdu_bytes),\
      \ pdu_bytes)\n            # Send PDU\n            self.message_port_pub(pmt.intern(\"\
      pdus\"), pmt.cons(pmt.PMT_NIL, pdu))\n            print(\"I SENT IT\")\n\n \
      \       return n_in\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    pdu_size: '32'
  states:
    _io_cache: ('ByteToPDUWithIdle', 'blk', [('pdu_size', '64')], [('0', 'byte', 1)],
      [('pdus', 'message', 1)], '\n    Convert continuous byte stream (including idle)
      to PDUs\n    ', ['pdu_size'])
    bus_sink: false

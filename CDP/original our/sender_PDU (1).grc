- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "import os, pmt\nfrom gnuradio import gr\n\ntry:\n    # PyCryptodome\n\
      \    from Crypto.Cipher import AES\nexcept ImportError:\n    AES = None\n\n\
      class aes_gcm_encrypt_pdu(gr.basic_block):\n    def __init__(self, key_hex=\"\
      00112233445566778899aabbccddeeff\"):\n        gr.basic_block.__init__(self,\n\
      \            name=\"AES-GCM Encrypt (PDU)\",\n            in_sig=[],\n     \
      \       out_sig=[]\n        )\n        self.message_port_register_in(pmt.intern(\"\
      pdus_in\"))\n        self.set_msg_handler(pmt.intern(\"pdus_in\"), self._handle)\n\
      \        self.message_port_register_out(pmt.intern(\"pdus_out\"))\n\n      \
      \  self.key = bytes.fromhex(key_hex)\n        if AES is None:\n            print(\"\
      [AES-GCM Encrypt] ERROR: PyCryptodome not found. Install with: pip install pycryptodome\"\
      )\n\n    def _handle(self, msg):\n        if AES is None:\n            return\n\
      \        meta = pmt.car(msg)\n        vec  = pmt.cdr(msg)\n        if not pmt.is_u8vector(vec):\n\
      \            print(\"[AES-GCM Encrypt] Non-u8vector payload\")\n           \
      \ return\n        data = bytearray(pmt.u8vector_elements(vec))\n        if len(data)\
      \ == 0:\n            return\n\n        # Keep first byte (seq) in clear; encrypt\
      \ the rest\n        seq = data[0:1]\n        plain = bytes(data[1:])\n\n   \
      \     # 12-byte IV (nonce)\n        iv = os.urandom(12)\n        cipher = AES.new(self.key,\
      \ AES.MODE_GCM, nonce=iv)\n\n        # Optionally bind AAD (e.g., sequence byte)\
      \ so tag covers it\n        cipher.update(seq)\n\n        ciphertext, tag =\
      \ cipher.encrypt_and_digest(plain)\n\n        # Output payload = [seq][IV(12)][ciphertext][tag(16)]\n\
      \        out = seq + iv + ciphertext + tag\n        out_u8 = pmt.init_u8vector(len(out),\
      \ list(out))\n        out_pdu = pmt.cons(meta, out_u8)\n        self.message_port_pub(pmt.intern(\"\
      pdus_out\"), out_pdu)\n"
    affinity: ''
    alias: ''
    comment: ''
    key_hex: '''00112233445566778899aabbccddeeff'''
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: ('AES-GCM Encrypt (PDU)', 'aes_gcm_encrypt_pdu', [('key_hex', "'00112233445566778899aabbccddeeff'")],
      [('pdus_in', 'message', 1)], [('pdus_out', 'message', 1)], '', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [408, 252.0]
    rotation: 0
    state: disabled
- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\"\"\"\n\nimport numpy as np\n\
      from gnuradio import gr\nimport pmt\n\nclass blk(gr.sync_block):\n    \"\"\"\
      \n    BitLimiter (fixed byte count):\n    - Wait for tag with name tag_key\n\
      \    - When seen, forward exactly packet_bytes bytes\n    \"\"\"\n\n    def\
      \ __init__(self, tag_key=\"packet_start\", packet_bytes=32):\n        gr.sync_block.__init__(\n\
      \            self,\n            name=\"BitLimiterBytes\",\n            in_sig=[np.uint8],\n\
      \            out_sig=[np.uint8]\n        )\n\n        self.tag_key = pmt.intern(tag_key)\n\
      \        self.packet_bytes = int(packet_bytes)\n\n        # State\n        self.active\
      \ = False\n        self.bytes_remaining = 0\n\n    def work(self, input_items,\
      \ output_items):\n\n        inp = input_items[0]\n        out = output_items[0]\n\
      \n        n_in = len(inp)\n        out_index = 0\n\n        # ---- Detect tag\
      \ ----\n        tags = self.get_tags_in_window(0, 0, n_in)\n\n        for t\
      \ in tags:\n            if t.key == self.tag_key:\n                # Start forwarding\
      \ packet_bytes bytes\n                self.bytes_remaining = self.packet_bytes\n\
      \                self.active = True\n\n        # ---- Forward data ----\n  \
      \      for i in range(n_in):\n\n            if self.active and self.bytes_remaining\
      \ > 0:\n                out[out_index] = inp[i]\n                out_index +=\
      \ 1\n                self.bytes_remaining -= 1\n\n                if self.bytes_remaining\
      \ == 0:\n                    self.active = False\n\n        return out_index\n\
      \n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    packet_bytes: '8'
    tag_key: '"packet_len"'
  states:
    _io_cache: ('BitLimiterBytes', 'blk', [('tag_key', "'packet_start'"), ('packet_bytes',
      '32')], [('0', 'byte', 1)], [('0', 'byte', 1)], '\n    BitLimiter (fixed byte
      count):\n    - Wait for tag with name tag_key\n    - When seen, forward exactly
      packet_bytes bytes\n    ', ['packet_bytes', 'tag_key'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1336, 1276.0]
    rotation: 0
    state: enabled
- name: epy_block_10
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\nclass\
      \ blk(gr.basic_block):\n\n    def __init__(self, num_bytes=4):\n        gr.basic_block.__init__(\n\
      \            self,\n            name=\"PDU Prepend Random Bytes\",\n       \
      \     in_sig=None,\n            out_sig=None\n        )\n\n        self.num_bytes\
      \ = int(num_bytes)\n\n        self.message_port_register_in(pmt.intern(\"in\"\
      ))\n        self.message_port_register_out(pmt.intern(\"out\"))\n\n        self.set_msg_handler(pmt.intern(\"\
      in\"), self.handle_msg)\n\n\n    def handle_msg(self, msg):\n        meta =\
      \ pmt.car(msg)\n        vec = pmt.cdr(msg)\n\n        payload = bytes(pmt.u8vector_elements(vec))\n\
      \n        # random bytes\n        prepend = np.random.randint(0, 256, self.num_bytes,\
      \ dtype=np.uint8).tolist()\n\n        # convert payload to list of ints\n  \
      \      payload_list = list(payload)\n\n        # final output list\n       \
      \ out_list = prepend + payload_list\n\n        # convert back to PDU\n     \
      \   out_vec = pmt.init_u8vector(len(out_list), out_list)\n\n        self.message_port_pub(\n\
      \            pmt.intern(\"out\"),\n            pmt.cons(meta, out_vec)\n   \
      \     )\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    num_bytes: '10000'
  states:
    _io_cache: ('PDU Prepend Random Bytes', 'blk', [('num_bytes', '4')], [('in', 'message',
      1)], [('out', 'message', 1)], '', ['num_bytes'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1112, 248.0]
    rotation: 0
    state: enabled
- name: epy_block_3
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Block: Idle + Packet Injector\n\"\"\"\n\
      \nimport numpy as np\nfrom gnuradio import gr\nimport pmt\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Continuous stream block with idle bytes 0xAA.\n    Injects\
      \ packets from input stream (Tagged Stream Mux) whenever available.\n    \"\"\
      \"\n    def __init__(self, idle_byte=0xAA):\n        gr.sync_block.__init__(\n\
      \            self,\n            name=\"IdlePacketInjector\",\n            in_sig=[np.uint8],\n\
      \            out_sig=[np.uint8]\n        )\n\n        self.idle_byte = idle_byte\n\
      \        self.packet_buffer = []\n\n    def work(self, input_items, output_items):\n\
      \        inp = input_items[0]\n        out = output_items[0]\n        print(inp)\n\
      \n        n_out = len(out)\n        in_len = len(inp)\n        out_index = 0\n\
      \n\n        # ---- Append input bytes to internal buffer ----\n        if in_len\
      \ > 0:\n            self.packet_buffer.extend(inp.tolist())\n\n        # ----\
      \ Fill output ----\n        while out_index < n_out:\n\n            if len(self.packet_buffer)\
      \ > 0:\n                # Pop from buffer\n                out[out_index] =\
      \ self.packet_buffer.pop(0)\n            else:\n                # Output idle\n\
      \                out[out_index] = self.idle_byte\n\n            out_index +=\
      \ 1\n\n        return n_out\n"

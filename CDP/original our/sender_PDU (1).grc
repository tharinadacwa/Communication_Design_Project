      \n        self.send_btn = QtWidgets.QPushButton(\"\u27A4\") \n        self.send_btn.setFixedSize(40,\
      \ 40)\n        self.send_btn.setStyleSheet(\"background-color: #3390EC; color:\
      \ white; border-radius: 20px; font-weight: bold;\")\n        self.send_btn.clicked.connect(self.on_send)\n\

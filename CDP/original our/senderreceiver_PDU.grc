- name: epy_block_12
  id: epy_block
  parameters:
    _source_code: "import pmt\nimport threading\nimport time\nfrom gnuradio import\
      \ gr\n\nclass TextToPDU_ARQ(gr.basic_block):\n    \"\"\"\n    Stop-and-Wait\
      \ ARQ with 10kB prepend, optimized to avoid repeated huge copies.\n    Algorithm\
      \ / protocol unchanged. Only internal implementation improved.\n    \"\"\"\n\
      \n    def __init__(self, max_packet_size=32, src_address=1, dest_address=2,\n\
      \                 interval=0.5, max_retries=20, prepend_size=10000):\n     \
      \   gr.basic_block.__init__(\n            self,\n            name=\"Text to\
      \ PDU (ARQ Logic + 10kB Prepend, optimized)\",\n            in_sig=[],\n   \
      \         out_sig=[]\n        )\n\n        # --- CONFIGURATION (user settable)\
      \ ---\n        self.interval = float(interval)                    # wait for\
      \ ACK timeout (s)\n        self.max_packet_size = int(max_packet_size)     \
      \   # as before\n        self.src_address = int(src_address) & 0xFF\n      \
      \  self.dest_address = int(dest_address) & 0xFF\n        self.max_retries =\
      \ int(max_retries)                # lowered default to avoid flooding\n    \
      \    self.prepend_size = int(prepend_size)              # 10000 by default\n\
      \        # -------------------------------------\n\n        # --- Prepare a\
      \ reusable prepend bytes object once (immutable bytes) ---\n        base = bytes([0x12,\
      \ 0x34, 0x56, 0x78, 0x9A, 0xBC, 0xDE, 0xF0])\n        # repeat base enough times\
      \ to reach prepend_size, then slice\n        repeats = (self.prepend_size +\
      \ len(base) - 1) // len(base)\n        self._prepend_bytes = (base * repeats)[:self.prepend_size]\
      \  # bytes object\n\n        # Message ports (same as before)\n        self.message_port_register_out(pmt.intern(\"\
      pdus\"))\n        self.message_port_register_in(pmt.intern(\"ack_bits\"))\n\
      \        self.set_msg_handler(pmt.intern(\"ack_bits\"), self.handle_ack_bits)\n\
      \n        self.message_port_register_in(pmt.intern(\"msg_in\"))\n        self.set_msg_handler(pmt.intern(\"\
      msg_in\"), self.handle_msg_input)\n        self.message_port_register_out(pmt.intern(\"\
      status_out\"))\n\n        # Threading / state\n        self._stop_event = threading.Event()\n\
      \        self._ack_event = threading.Event()\n        self._ack_lock = threading.Lock()\n\
      \        self._expected_ack = None\n        self._tx_lock = threading.Lock()\
      \    # prevent overlapping transmissions\n\n    def stop(self):\n        self._stop_event.set()\n\
      \        self._ack_event.set()\n        return super().stop()\n\n    def handle_msg_input(self,\
      \ msg):\n        # identical external behavior: read symbol and spawn worker\
      \ if idle\n        try:\n            text_data = pmt.symbol_to_string(msg)\n\
      \        except Exception:\n            # keep silent if not convertable\n \
      \           return\n\n        if self._tx_lock.locked():\n            # Busy:\
      \ same behavior as before\n            return\n\n        t = threading.Thread(target=self._process_transmission,\
      \ args=(text_data,))\n        t.daemon = True\n        t.start()\n\n    def\
      \ _process_transmission(self, text_data):\n        # Acquire tx lock to ensure\
      \ exactly one transmission at a time\n        with self._tx_lock:\n        \
      \    self.message_port_pub(pmt.intern(\"status_out\"), pmt.intern(\"pending\"\
      ))\n\n            data = text_data.encode('utf-8')\n            # chunk_size\
      \ remains the same (max_packet_size - 3 header bytes)\n            chunk_size\
      \ = self.max_packet_size - 3\n            chunks = [data[i:i + chunk_size] for\
      \ i in range(0, len(data), chunk_size)]\n\n            packet_number = 1\n \
      \           success = True\n\n            # --- Helper: build & cache packet\
      \ PMT once per packet_number ---\n            def make_cached_pdu(packet_number,\
      \ payload_bytes):\n                \"\"\"\n                Returns a (pdu, packet_number)\
      \ where pdu is a PMT cons(PMT_NIL, u8vector)\n                The u8vector is\
      \ constructed once and can be reused for retries.\n                \"\"\"\n\
      \                header = bytes([self.src_address, self.dest_address, packet_number])\n\
      \                # build final bytes - this creates one bytes object for the\
      \ whole packet\n                full_packet_bytes = self._prepend_bytes + header\
      \ + payload_bytes\n                # create u8vector once (using bytes directly\
      \ is supported by many PMT builds)\n                vec = pmt.init_u8vector(len(full_packet_bytes),\
      \ full_packet_bytes)\n                pdu = pmt.cons(pmt.PMT_NIL, vec)\n   \
      \             return pdu\n\n            # --- SEND NORMAL PACKETS (Stop-and-Wait)\
      \ ---\n            for chunk in chunks:\n                if self._stop_event.is_set():\n\
      \                    success = False\n                    break\n\n        \
      \        # Build PDU once and reuse on retries\n                pdu = make_cached_pdu(packet_number,\
      \ chunk)\n\n                # wait-for-ack loop (retries)\n                with\
      \ self._ack_lock:\n                    self._expected_ack = packet_number\n\
      \                    self._ack_event.clear()\n\n                attempt = 0\n\
      \                chunk_sent_successfully = False\n\n                while attempt\
      \ < self.max_retries and not self._stop_event.is_set():\n                  \
      \  # publish the exact same PMT PDU (no metadata dict creation)\n          \
      \          self.message_port_pub(pmt.intern(\"pdus\"), pdu)\n\n            \
      \        # wait for ack (blocks the thread only)\n                    ack_received\
      \ = self._ack_event.wait(timeout=self.interval)\n                    if ack_received:\n\
      \                        chunk_sent_successfully = True\n                  \
      \      break\n\n                    attempt += 1\n                    # small\
      \ backoff to avoid tight flood of retries (reduces downstream pressure)\n  \
      \                  time.sleep(0.001)\n\n                if not chunk_sent_successfully:\n\
      \                    print(f\"[ARQ] Failed to send packet #{packet_number:02X}\
      \ after {attempt} attempts\")\n                    success = False\n       \
      \             break\n\n                # increment packet number with wrap (skip\
      \ 0x00)\n                packet_number = (packet_number + 1) & 0xFF\n      \
      \          if packet_number == 0x00:\n                    packet_number = 0x01\n\
      \n            # --- SEND TERMINATION PACKET ---\n            if success and\
      \ not self._stop_event.is_set():\n                term_packet_number = packet_number\n\
      \                term_payload_len = (self.max_packet_size + 1) - 3\n       \
      \         term_payload = bytes([0xFF] * term_payload_len)\n\n              \
      \  pdu = make_cached_pdu(term_packet_number, term_payload)\n\n             \
      \   with self._ack_lock:\n                    self._expected_ack = term_packet_number\n\
      \                    self._ack_event.clear()\n\n                attempt = 0\n\
      \                term_success = False\n\n                while attempt < self.max_retries\
      \ and not self._stop_event.is_set():\n                    self.message_port_pub(pmt.intern(\"\
      pdus\"), pdu)\n\n                    if self._ack_event.wait(timeout=self.interval):\n\
      \                        term_success = True\n                        break\n\
      \n                    attempt += 1\n                    time.sleep(0.001)\n\n\
      \                if not term_success:\n                    print(f\"[ARQ] Failed\
      \ to send TERMINATION packet #{term_packet_number:02X} after {attempt} attempts\"\
      )\n                    success = False\n\n            # --- Final status publish\
      \ ---\n            if success:\n                self.message_port_pub(pmt.intern(\"\
      status_out\"), pmt.intern(\"success\"))\n            else:\n               \
      \ self.message_port_pub(pmt.intern(\"status_out\"), pmt.intern(\"fail\"))\n\n\
      \    def handle_ack_bits(self, msg):\n        # exactly same validation as before,\
      \ but very strict and early-return on bad types\n        try:\n            data\
      \ = pmt.cdr(msg)\n            if not pmt.is_u8vector(data):\n              \
      \  return\n\n            byte_data = bytearray(pmt.u8vector_elements(data))\n\
      \            if len(byte_data) < 4:\n                return\n            if\
      \ byte_data[0] != 0xAA:\n                return\n\n            ack_src_addr\
      \ = byte_data[1]\n            ack_dest_addr = byte_data[2]\n            ack_packet_num\
      \ = byte_data[3]\n\n            if ack_dest_addr != self.src_address:\n    \
      \            return\n            if ack_src_addr != self.dest_address:\n   \
      \             return\n\n            with self._ack_lock:\n                if\
      \ ack_packet_num == self._expected_ack:\n                    # set event for\
      \ the thread waiting on this ack\n                    self._ack_event.set()\n\
      \n        except Exception as e:\n            # keep error reporting but don't\
      \ crash\n            print(f\"[ARQ] Error handling ACK: {str(e)}\")\n\n"
    affinity: ''
    alias: ''
    comment: ''

    state: disabled
- name: epy_block_3_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"\n    Idle + Packet Injector\n    Waits until the full packet (according\
      \ to header length) is received before transmitting.\n    \"\"\"\n    def __init__(self,\
      \ idle_byte=0xAA):\n        gr.sync_block.__init__(\n            self,\n   \
      \         name=\"IdlePacketInjector\",\n            in_sig=[np.uint8],\n   \
      \         out_sig=[np.uint8]\n        )\n\n        self.idle_byte = idle_byte\n\
      \        self.packet_buffer = []\n        self.expected_length = None  # Total\
      \ packet length including header\n\n    def work(self, input_items, output_items):\n\
      \        inp = input_items[0]\n        out = output_items[0]\n\n        n_out\
      \ = len(out)\n        out_index = 0\n\n        # ---- Append input bytes to\
      \ internal buffer ----\n        if len(inp) > 0:\n            self.packet_buffer.extend(inp.tolist())\n\
      \n\n        # ---- Extract expected packet length from header ----\n       \
      \ # Header format: XX XX XX XX 00 <length_byte> 00 <length_byte>\n        if\
      \ self.expected_length is None and len(self.packet_buffer) >= 6:\n         \
      \   length_byte = self.packet_buffer[5]  # 0-based index for first length byte\n\
      \            self.expected_length = 8 + length_byte  # 8-byte header + payload\n\
      \n        # ---- Fill output ----\n        while out_index < n_out:\n      \
      \      if self.expected_length is not None and len(self.packet_buffer) >= self.expected_length:\n\
      \                # Full packet ready: transmit first byte\n                out[out_index]\
      \ = self.packet_buffer.pop(0)\n                # If entire packet transmitted,\
      \ reset expected_length\n                if len(self.packet_buffer) == 0:\n\
      \                    self.expected_length = None\n            else:\n      \
      \          # Not enough bytes yet: output idle\n                out[out_index]\
      \ = self.idle_byte\n\n            out_index += 1\n\n        return n_out\n"
    affinity: ''
    alias: ''
    comment: ''
    idle_byte: '170'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: ('IdlePacketInjector', 'blk', [('idle_byte', '170')], [('0', 'byte',
      1)], [('0', 'byte', 1)], '\n    Idle + Packet Injector\n    Waits until the
      full packet (according to header length) is received before transmitting.\n    ',
      ['idle_byte'])
    bus_sink: false
    bus_source: false

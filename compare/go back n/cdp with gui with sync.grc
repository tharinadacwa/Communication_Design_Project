      ''100''), (''window_size'', ''4''), (''sync_bits'', ''1000'')], [(''ack_in'',
      ''message'', 1), (''in'', ''message'', 1)], [(''feedback'', ''message'', 1),
      (''out'', ''message'', 1)], ''\n    Custom block: QT GUI Message Entry -> PDU
      sender with Go-Back-N ARQ.\n    NOW SUPPORTS:\n    - sync_bits : number of random
      bytes transmitted before each retransmission.\n    - Sync burst has NO headers,
      NO packetization. It is PURE RANDOM BYTE STREAM.\n    '', [])'

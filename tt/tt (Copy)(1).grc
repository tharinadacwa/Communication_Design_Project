- name: epy_block_12
  id: epy_block
  parameters:
    _source_code: "#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\nimport threading\n\
      import pmt\nimport time\nimport os\nfrom gnuradio import gr\n\nclass TextToPDU_ARQ(gr.basic_block):\n\
      \n    def __init__(self, pkt_size=32, src_addr=1, dst_addr=2,\n            \
      \     sync_burst_bytes=10000, timeout=0.1, retry_limit=200):\n\n        gr.basic_block.__init__(\n\
      \            self,\n            name=\"Text to PDU ARQ (Variable Burst)\",\n\
      \            in_sig=[],\n            out_sig=[]\n        )\n\n        # ----------------\
      \ PARAMETERS ----------------\n        self._pkt_size = int(pkt_size)\n    \
      \    self._src = int(src_addr) & 0xFF\n        self._dst = int(dst_addr) & 0xFF\n\
      \        \n        # --- BURST SIZES SETUP ---\n        self._sync_len_first\
      \ = int(sync_burst_bytes) # Default: 10000\n        self._sync_len_next = 5000\
      \                  # Fixed: 160\n        \n        self._timeouttotal = 0.5\n\
      \        \n        self._timeout = float(timeout)\n        self._retry_limit\
      \ = int(retry_limit)\n        # --------------------------------------------\n\
      \n        # Ports\n        self.message_port_register_in(pmt.intern(\"msg_in\"\
      ))\n        self.message_port_register_in(pmt.intern(\"ack_in\"))\n        self.message_port_register_out(pmt.intern(\"\
      pdus\"))\n        self.message_port_register_out(pmt.intern(\"status_out\"))\n\
      \n        self.set_msg_handler(pmt.intern(\"msg_in\"), self._process_text)\n\
      \        self.set_msg_handler(pmt.intern(\"ack_in\"), self._process_ack)\n\n\
      \        # State\n        self._tx_thread = None\n        self._stop = threading.Event()\n\
      \        self._ack_event = threading.Event()\n        self._ack_lock = threading.Lock()\n\
      \        self._expected_ack = None\n\n    # ================================================================\n\
      \    #  SEND SYNC BURST (CREATION HAPPENS HERE)\n    # ================================================================\n\
      \    def _send_prepend_burst(self, length):\n        \"\"\"\n        Creates\
      \ a burst of random bytes of the specific 'length' requested.\n        \"\"\"\
      \n        if length <= 0:\n            return\n\n        # --- THIS IS WHERE\
      \ THE BURST IS CREATED ---\n        # It creates exactly 'length' bytes (10000\
      \ or 1000)\n        raw = os.urandom(length)\n        \n        vec = pmt.init_u8vector(len(raw),\
      \ list(raw))\n        pdu = pmt.cons(pmt.PMT_NIL, vec)\n\n        # Debug print\
      \ to confirm size\n        # if length > 2000:\n        #     print(f\"[ARQ]\
      \ PREPEND LARGE BURST ({len(raw)} bytes)\")\n        # else:\n        #    print(f\"\
      [ARQ] Prepend small burst ({len(raw)} bytes)\")\n        \n        self.message_port_pub(pmt.intern(\"\
      pdus\"), pdu)\n\n    # ================================================================\n\
      \    #  HANDLE INPUT TEXT\n    # ================================================================\n\
      \    def _process_text(self, msg):\n        try:\n            text = pmt.symbol_to_string(msg)\n\
      \        except:\n            return\n\n        if self._tx_thread is None or\
      \ not self._tx_thread.is_alive():\n            self._stop.clear()\n        \
      \    self._tx_thread = threading.Thread(target=self._run, args=(text,))\n  \
      \          self._tx_thread.daemon = True\n            self._tx_thread.start()\n\
      \n    # ================================================================\n \
      \   #  MAIN TRANSMISSION (DECISION HAPPENS HERE)\n    # ================================================================\n\
      \    def _run(self, text):\n        data = text.encode(\"utf-8\")\n        chunk_size\
      \ = self._pkt_size - 3\n        chunks = [data[i:i+chunk_size] for i in range(0,\
      \ len(data), chunk_size)]\n\n        pkt_num = 1\n        success = True\n\n\
      \        # ---------------- NORMAL PACKETS ----------------\n        # for i,\
      \ chunk in enumerate(chunks):\n            \n        #     # --- DECIDE SIZE\
      \ ---\n        #     if i == 0:\n        #         # First packet: Create 10,000\
      \ bytes\n        #         current_burst_len = self._sync_len_first\n      \
      \  #     else:\n        #         # Subsequent packets: Create 1,000 bytes\n\
      \        #         current_burst_len = self._sync_len_next\n\n        #    \
      \ if not self._send_single_packet(chunk, pkt_num, current_burst_len):\n    \
      \    #         success = False\n        #         break\n\n        #     pkt_num\
      \ = (pkt_num + 1) & 0xFF\n        #     if pkt_num == 0:\n        #        \
      \ pkt_num = 1\n\n\n\n\n       # ---------------- NORMAL PACKETS ----------------\n\
      \        \n            \n            # --- DECIDE SIZE ---\n        if pkt_num\
      \ == 0:\n            # First packet: Create 10,000 bytes\n            current_burst_len\
      \ = self._sync_len_first\n        else:\n            # Subsequent packets: Create\
      \ 1,000 bytes\n            current_burst_len = self._sync_len_next\n       \
      \ for chunk in chunks:\n            if not self._send_single_packet(chunk, pkt_num,\
      \ current_burst_len):\n                success = False\n                break\n\
      \n            pkt_num = (pkt_num + 1) & 0xFF\n            if pkt_num == 0:\n\
      \                pkt_num = 1\n\n        # ---------------- TERMINATION PACKET\
      \ ----------------\n        if success and not self._stop.is_set():\n      \
      \      term_size = (self._pkt_size + 1) - 3\n            term_payload = bytes([0xFF]\
      \ * term_size)\n            \n            # Termination packet gets the small\
      \ burst (1000)\n            if not self._send_single_packet(term_payload, pkt_num,\
      \ self._sync_len_next, termination=True):\n                success = False\n\
      \n        # ---------------- UPDATE GUI ----------------\n        if success:\n\
      \            self.message_port_pub(pmt.intern(\"status_out\"), pmt.intern(\"\
      success\"))\n        else:\n            self.message_port_pub(pmt.intern(\"\
      status_out\"), pmt.intern(\"fail\"))\n\n    # ================================================================\n\
      \    #  SEND ONE PACKET WITH ARQ\n    # ================================================================\n\
      \    def _send_single_packet(self, chunk, pkt_num, burst_len, termination=False):\n\
      \n        header = bytes([self._src, self._dst, pkt_num])\n        full_packet\
      \ = header + chunk\n\n        vec = pmt.init_u8vector(len(full_packet), list(full_packet))\n\
      \        pdu = pmt.cons(pmt.PMT_NIL, vec)\n\n        with self._ack_lock:\n\
      \            self._expected_ack = pkt_num\n            self._ack_event.clear()\n\
      \n        retries = 0\n\n        while retries < self._retry_limit and not self._stop.is_set():\n\
      \n            # --- EXECUTE CREATION ---\n            # We call the function\
      \ to create 'burst_len' bytes\n            \n            if self._retry_limit\
      \ % 10 == 0:\n                self._send_prepend_burst(burst_len)\n\n      \
      \      # SEND PACKET\n            self.message_port_pub(pmt.intern(\"pdus\"\
      ), pdu)\n            print(f\"[ARQ] Sent packet #{pkt_num:02X} (Burst: {burst_len})\"\
      )\n\n            # WAIT FOR ACK\n            #if self._ack_event.wait(timeout=self._timeout):\n\
      \            #    print(f\"[ARQ] ACK for #{pkt_num:02X}\")\n            #  \
      \  return True\n\n            retries += 1\n            print(f\"[ARQ] Timeout\
      \ \u2192 retry {retries}\")\n        \n        print(f\"waiting for chunk ack\"\
      )\n        if self._ack_event.wait(timeout=self._timeouttotal):\n          \
      \      print(f\"[ARQ] ACK for #{pkt_num:02X}\")\n                return True\n\
      \n        #print(f\"[ARQ] FAILED packet #{pkt_num:02X}\")\n        #return False\n\
      \        print(f\"[ARQ] FAILED packet #{pkt_num:02X}\")\n\n        # -----------------------------------------------------\n\
      \        # EXTRA WAIT FOR LATE ACK (only after last retry)\n        # -----------------------------------------------------\n\
      \        print(\"[ARQ] Waiting extra time for possible late ACK...\")\n    \
      \    extra_wait = 10   # \u2190 you can adjust\n\n        if self._ack_event.wait(timeout=extra_wait):\n\
      \            print(\"[ARQ] Late ACK received! Accepting packet.\")\n       \
      \     return True\n\n        print(\"[ARQ] No late ACK. Final failure.\")\n\
      \        # -----------------------------------------------------\n\n       \
      \ return False\n\n\n    # ================================================================\n\
      \    #  ACK HANDLER\n    # ================================================================\n\
      \    def _process_ack(self, msg):\n        try:\n            data = pmt.cdr(msg)\n\
      \            if not pmt.is_u8vector(data):\n                return\n\n     \
      \       arr = bytearray(pmt.u8vector_elements(data))\n            if len(arr)\
      \ < 4:\n                return\n            if arr[0] != 0xAA:\n           \
      \     return\n\n            src = arr[1]\n            dst = arr[2]\n       \
      \     ack_id = arr[3]\n\n            if src != self._dst or dst != self._src:\n\
      \                return\n\n            with self._ack_lock:\n              \
      \  if ack_id == self._expected_ack:\n                    self._ack_event.set()\n\
      \n        except Exception as e:\n            print(f\"[ARQ] ACK error: {e}\"\
      )\n"
    affinity: ''
    alias: ''
    comment: ''
    dst_addr: '2'
    maxoutbuf: '0'
    minoutbuf: '0'
    pkt_size: '32'
    retry_limit: '60'
    src_addr: '1'
    sync_burst_bytes: '10000'
    timeout: '0.01'
  states:
    _io_cache: ('Text to PDU ARQ (Variable Burst)', 'TextToPDU_ARQ', [('pkt_size',
      '32'), ('src_addr', '1'), ('dst_addr', '2'), ('sync_burst_bytes', '10000'),
      ('timeout', '0.1'), ('retry_limit', '200')], [('ack_in', 'message', 1), ('msg_in',
      'message', 1)], [('status_out', 'message', 1), ('pdus', 'message', 1)], '',
      [])
    bus_sink: false
    bus_source: false
    bus_structure: null

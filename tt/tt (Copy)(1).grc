      , \"#3390EC\")\n            elif status_str == \"fail\":\n                self.gui.status_signal.emit(\"\
      Failed\", \"red\")\n            elif status_str == \"pending\":\n          \
      \      pass\n\n        except Exception as e:\n            print(f\"[GUI] Error\
      \ handling status: {e}\")\n\n    def stop(self):\n        self.gui.close()\n\
      \        return super().stop()"

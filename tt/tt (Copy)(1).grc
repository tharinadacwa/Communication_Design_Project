      \    \"\"\"A custom widget to render a message bubble\"\"\"\n    def __init__(self,\
      \ text, time_str, status=\"Waiting\", parent=None):\n        super().__init__(parent)\n\
      \        self.layout = QtWidgets.QHBoxLayout()\n        self.layout.setContentsMargins(0,\

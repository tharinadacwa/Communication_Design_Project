- name: epy_block_4
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\n\nclass blk(gr.basic_block):\n\
      \    \"\"\"\n    PDU Prepend Pattern Bytes (fast & PMT-compatible)\n\n    -\
      \ Prepends a fixed byte pattern to each incoming PDU.\n    - Avoids expensive\
      \ per-PDU slicing by precomputing pattern chunks.\n    \"\"\"\n\n    def __init__(self,\
      \ num_bytes=4):\n        gr.basic_block.__init__(\n            self,\n     \
      \       name=\"PDU Prepend Pattern Bytes\",\n            in_sig=None,\n    \
      \        out_sig=None\n        )\n\n        self.num_bytes = int(num_bytes)\n\
      \n        # ----------------------------------------------------\n        #\
      \ Pre-generated pattern: 8-byte sequence repeated\n        # Convert immediately\
      \ to list[int] for fast concatenation\n        # ----------------------------------------------------\n\
      \        base = bytes.fromhex(\"12 34 56 78 9A BC DE F0\")\n        self.pattern_bytes\
      \ = list(base * ((self.num_bytes // len(base)) + 1))\n        # Keep only exactly\
      \ num_bytes length\n        self.pattern_bytes = self.pattern_bytes[:self.num_bytes]\n\
      \n        # ----------------------------------------------------\n        #\
      \ Message ports\n        # ----------------------------------------------------\n\
      \        self.message_port_register_in(pmt.intern(\"in\"))\n        self.message_port_register_out(pmt.intern(\"\
      out\"))\n\n        self.set_msg_handler(pmt.intern(\"in\"), self.handle_msg)\n\
      \n    def handle_msg(self, msg):\n        meta = pmt.car(msg)\n        vec =\
      \ pmt.cdr(msg)\n\n        # Convert incoming payload to list[int] for PMT\n\
      \        payload_list = list(pmt.u8vector_elements(vec))\n\n        # Concatenate\
      \ pattern + payload (list of ints)\n        out_list = self.pattern_bytes +\
      \ payload_list\n\n        # Create PMT u8vector\n        out_vec = pmt.init_u8vector(len(out_list),\
      \ out_list)\n\n        # Publish new PDU\n        self.message_port_pub(\n \
      \           pmt.intern(\"out\"),\n            pmt.cons(meta, out_vec)\n    \
      \    )\n\n"

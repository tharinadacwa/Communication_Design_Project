- name: epy_block_3_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass IdlePacketInjectorWithLength(gr.sync_block):\n\
      \    \"\"\"\n    Idle + Packet Injector (robust version)\n    - Continuously\
      \ outputs idle bytes until a full packet is buffered.\n    - Transmits the entire\
      \ packet (with payload-length byte first) once ready.\n    - Supports back-to-back\
      \ packets in the buffer.\n    \"\"\"\n    def __init__(self, idle_byte=0xAA):\n\
      \        gr.sync_block.__init__(\n            self,\n            name=\"IdlePacketInjectorWithLength\"\
      ,\n            in_sig=[np.uint8],\n            out_sig=[np.uint8]\n        )\n\
      \n        self.idle_byte = idle_byte\n        self.packet_buffer = []\n    \
      \    self.expected_length = None  # total length including header\n        self.payload_length\
      \ = None\n        self.send_length_byte = False\n        self.sentcount = 0\n\
      \n    def work(self, input_items, output_items):\n        inp = input_items[0]\n\
      \        out = output_items[0]\n        n_out = len(out)\n        out_index\
      \ = 0\n\n        # ---- Append new bytes to internal buffer ----\n        if\
      \ len(inp) > 0:\n            self.packet_buffer.extend(inp.tolist())\n\n   \
      \     # ---- Process output buffer ----\n        while out_index < n_out:\n\n\
      \            # ---- Check if a full packet is available ----\n            if\
      \ self.expected_length is None and len(self.packet_buffer) >= 6:\n         \
      \       # Extract payload length from header\n                self.payload_length\
      \ = self.packet_buffer[5]  # 0-based index\n                self.expected_length\
      \ = 8 + self.payload_length\n                self.send_length_byte = True\n\
      \                self.sentcount = 0\n\n            # ---- If full packet is\
      \ ready, transmit it ----\n            if self.expected_length is not None and\
      \ len(self.packet_buffer) >= self.expected_length:\n                if self.send_length_byte:\n\
      \                    # Send payload-length byte first\n                    out[out_index]\
      \ = self.payload_length\n                    self.send_length_byte = False\n\
      \                    out_index += 1\n                    continue  # continue\
      \ without incrementing out_index again\n                else:\n            \
      \        # Send packet bytes\n                    out[out_index] = self.packet_buffer.pop(0)\n\
      \                    print(out[out_index])\n                    self.sentcount\
      \ += 1\n\n                    # Check if packet transmission is complete\n \
      \                   if self.sentcount >= self.payload_length:\n            \
      \            # Remove header bytes as well\n                        for _ in\
      \ range(8):\n                            if self.packet_buffer:\n          \
      \                      self.packet_buffer.pop(0)\n                        #\
      \ Reset state for next packet\n                        self.expected_length\
      \ = None\n                        self.payload_length = None\n             \
      \           self.send_length_byte = False\n                        self.sentcount\
      \ = 0\n            else:\n                # Not enough bytes: send idle\n  \
      \              out[out_index] = self.idle_byte\n\n            out_index += 1\n\
      \n        return n_out\n"
    affinity: ''
    alias: ''
    comment: ''
    idle_byte: '170'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: ('IdlePacketInjectorWithLength', 'IdlePacketInjectorWithLength', [('idle_byte',
      '170')], [('0', 'byte', 1)], [('0', 'byte', 1)], '\n    Idle + Packet Injector
      (robust version)\n    - Continuously outputs idle bytes until a full packet
      is buffered.\n    - Transmits the entire packet (with payload-length byte first)
      once ready.\n    - Supports back-to-back packets in the buffer.\n    ', ['idle_byte'])
    bus_sink: false
